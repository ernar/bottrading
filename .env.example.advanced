# ============================================================
# .env.example.advanced — Ejemplo completo con límites de operaciones
# ============================================================
# 
# Este archivo muestra una configuración avanzada del bot con límites
# de operaciones máximas por símbolo y modelo LLM.
#
# Pasos para usar:
#   1. Copia este archivo a .env
#   2. Reemplaza las credenciales MT4 con las tuyas
#   3. Ajusta los límites de operaciones según tu estrategia de riesgo
#   4. Ejecuta: python main.py o start.bat
#
# La precedencia de configuración es: símbolo > modelo > default > hardcoded
#

# ============================================================
# PLATAFORMA (exclusiva MT4)
# ============================================================
MT_VERSION=mt4

# ============================================================
# MT4 (EA bridge - PythonBridge.mq4)
# ============================================================
MT4_LOGIN=0
MT4_PASSWORD=
MT4_HOST=127.0.0.1
MT4_PORT=8765

# ============================================================
# MODELOS LLM
# ============================================================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AI_PROVIDER=gemini
MODEL=gemini-2.0-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama local (desactivado por defecto en VPS):
OLLAMA_ENABLED=false
OLLAMA_MODELS=qwen3:8b,llama2:latest

# ============================================================
# BOT
# ============================================================
SYMBOLS=BTCUSD

# ============================================================
# API / DASHBOARD
# ============================================================
API_HOST=127.0.0.1
API_TOKEN=

# ============================================================
# GESTIÓN DE RIESGO
# ============================================================
MAX_DAILY_LOSS_PCT=0.05
# Ventana móvil del circuit breaker en segundos (default 21600 = 6 h).
RISK_LOSS_WINDOW_SECONDS=21600

# ============================================================
# LÍMITES DE OPERACIONES MÁXIMAS — EJEMPLOS
# ============================================================
#
# CASO DE USO: Quieres ser conservador con Bitcoin (máx 2 operaciones)
# pero más agresivo con otros símbolos (máx 5). Con qwen3:8b quieres
# permitir 3 operaciones, pero con GPT-4 máximo 4.
#
# Precedencia: símbolo específico gana sobre modelo, modelo gana sobre default.
# 

# --- Límites por símbolo (precedencia 1) ---
MAX_OPEN_POSITIONS_BTCUSD=2        # Bitcoin: solo 2 operaciones máximo
MAX_OPEN_POSITIONS_EURUSD=3        # Euro: conservador, 3 operaciones
MAX_OPEN_POSITIONS_GBPUSD=4        # Libra: un poco más agresivo

# --- Límites por modelo (precedencia 2) ---
# Si usas múltiples modelos, puedes ajustarlos aquí
MAX_OPEN_POSITIONS_QWEN3_8B=3      # Modelo local: conservador
MAX_OPEN_POSITIONS_GPT4=5          # GPT-4: permite más operaciones

# --- Límite global fallback (precedencia 3) ---
# Si no está configurado un símbolo ni modelo, usa este
MAX_OPEN_POSITIONS_DEFAULT=5

# ============================================================
# PARÁMETROS AVANZADOS POR SÍMBOLO/MODELO
# ============================================================
#
# También puedes configurar otros parámetros del agente como:
# min_confidence, min_rr, atr_sl_mult, atr_tp_mult, max_spread_filter,
# risk_per_trade, lot_size, temperature
#
# Ejemplo: Bitcoin debe tener mayor confianza y mejor R:R por volatilidad
#

# --- Parámetros para Bitcoin ---
MIN_CONFIDENCE_BTCUSD=0.7          # Exige mayor confianza
MIN_RR_BTCUSD=2.0                  # Exige mejor ratio riesgo/recompensa
ATR_SL_MULT_BTCUSD=1.8             # Stop loss más amplio (volatilidad)
ATR_TP_MULT_BTCUSD=2.7             # Take profit más amplio
RISK_PER_TRADE_BTCUSD=0.02         # Riesgo máximo del 2% por operación

# --- Parámetros para Euro (menos volátil) ---
MIN_CONFIDENCE_EURUSD=0.65
MIN_RR_EURUSD=1.5                  # Menos exigente que Bitcoin
ATR_SL_MULT_EURUSD=1.5
RISK_PER_TRADE_EURUSD=0.025        # Riesgo un poco mayor (menos volátil)

# --- Parámetros globales (fallback) ---
MIN_CONFIDENCE_DEFAULT=0.6
MIN_RR_DEFAULT=1.5
TEMPERATURE_DEFAULT=0.2
LOT_SIZE_DEFAULT=0.01
MAX_SPREAD_FILTER_DEFAULT=2.0

# ============================================================
# CÓMO LEER ESTA CONFIGURACIÓN
# ============================================================
#
# Ejemplo 1: BTCUSD + qwen3:8b
#   Resolución de MAX_OPEN_POSITIONS:
#     1. ¿Existe MAX_OPEN_POSITIONS_BTCUSD? → Sí = 2 ✓ FIN
#   Resultado: 2 operaciones máximo
#
# Ejemplo 2: EURUSD + qwen3:8b
#   Resolución de MAX_OPEN_POSITIONS:
#     1. ¿Existe MAX_OPEN_POSITIONS_EURUSD? → Sí = 3 ✓ FIN
#   Resultado: 3 operaciones máximo
#
# Ejemplo 3: GBPUSD + gpt-4 (GPT-4 no configurado por símbolo)
#   Resolución de MAX_OPEN_POSITIONS:
#     1. ¿Existe MAX_OPEN_POSITIONS_GBPUSD? → Sí = 4 ✓ FIN
#   Resultado: 4 operaciones máximo
#
# Ejemplo 4: NZDUSD + qwen3:8b (no hay config específica)
#   Resolución de MAX_OPEN_POSITIONS:
#     1. ¿Existe MAX_OPEN_POSITIONS_NZDUSD? → No
#     2. ¿Existe MAX_OPEN_POSITIONS_QWEN3_8B? → Sí = 3 ✓ FIN
#   Resultado: 3 operaciones máximo
#
# Ejemplo 5: AUDUSD + gemini (sin config específica de símbolo ni modelo)
#   Resolución de MAX_OPEN_POSITIONS:
#     1. ¿Existe MAX_OPEN_POSITIONS_AUDUSD? → No
#     2. ¿Existe MAX_OPEN_POSITIONS_GEMINI? → No
#     3. ¿Existe MAX_OPEN_POSITIONS_DEFAULT? → Sí = 5 ✓ FIN
#   Resultado: 5 operaciones máximo (default)
#
# Para ver cómo se resuelven realmente, ejecuta:
#   python examples_config.py
#
