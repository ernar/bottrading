# ============================================================
# Plantilla de configuración. Copia este archivo a `.env` y rellena
# tus valores reales. NUNCA subas el `.env` al repositorio.
# ============================================================

# PLATAFORMA: exclusiva MT4 (EA bridge)
MT_VERSION=mt4

# ============================================================
# MT4 (EA bridge - PythonBridge.mq4)
# ============================================================
MT4_LOGIN=0
MT4_PASSWORD=
MT4_HOST=127.0.0.1
MT4_PORT=8765
# Servidor del broker (tal y como aparece en MT4, p. ej. "ICMarketsSC-Demo").
MT4_SERVER=
# RELOGIN AL ARRANCAR: si defines la ruta a terminal.exe, main.py cierra y
# relanza el terminal con auto-login (usa MT4_LOGIN/MT4_PASSWORD/MT4_SERVER).
# Déjalo vacío para no tocar el terminal ya abierto.
MT4_TERMINAL_PATH=
# Segundos a esperar tras relanzar, a que MT4 inicie sesión y cargue el EA.
MT4_RELOGIN_WAIT=12

# ============================================================
# ZONA HORARIA DEL BRÓKER
# ============================================================
# Offset GMT del servidor del bróker, en horas (p. ej. 3 para un bróker en GMT+3).
# TODO el backend sella sus marcas (señales, trades, equity, memoria, aperturas/
# cierres) en HORA DEL BRÓKER usando este valor (UTC del equipo + offset), para no
# mezclar la hora local de la máquina con los epochs del bróker. Funciona igual en
# local que en un VPS de otra zona (se ancla en UTC, no en la hora de la máquina).
# El dashboard las muestra aplicando un desplazamiento fijo de visualización
# (DISPLAY_OFFSET_HOURS en src/utils/format.ts del repo del dashboard) = (tu zona) − (zona bróker).
#
# Escenario actual: equipo en UTC+2 y bróker 1 h por delante => bróker en UTC+3.
#   MT_SERVER_GMT_OFFSET=3   y   DISPLAY_OFFSET_HOURS=-1  (resta 1 h para tu hora).
# Si cambia el horario de verano y la diferencia deja de ser 1 h, reajusta ambos.
MT_SERVER_GMT_OFFSET=3

# ============================================================
# GOOGLE GEMINI — proveedor principal
# ============================================================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# El selector ofrece una lista curada de modelos recomendados (gemini-3.5-flash,
# gemini-2.5-pro, gemini-2.5-flash, gemini-2.0-flash) intersectada con los que tu
# cuenta tiene. Para forzar otra lista manual (coma) y saltarte el filtro:
# GEMINI_MODELS=gemini-3.5-flash,gemini-2.5-pro
# Proveedor activo: gemini | openai | deepseek | ollama
AI_PROVIDER=gemini
# Modelo por defecto (se sobreescribe al iniciar el bot)
MODEL=gemini-2.0-flash
# Timeout (segundos) de TODAS las llamadas al LLM (especialistas y mesa). Evita
# que una petición colgada congele el bucle (p. ej. la mesa parada para siempre
# en "Decidiendo asignación"). Al expirar, la mesa cae a su decisión determinista
# y el especialista se salta ese ciclo. Default 180s (generoso para modelos
# pensantes). 0 o vacío con valor <=0 => sin timeout.
# LLM_TIMEOUT_SECONDS=180

# ============================================================
# ASISTENTE (RESPONSABLE DE LA ORGANIZACIÓN)
# ============================================================
# Chatbot del dashboard que actúa como el director de la mesa: responde
# preguntas consultando el estado en vivo del bot (cuenta, posiciones, mesa,
# agentes). El proveedor/modelo se eligen con un desplegable en Ajustes →
# Asistente (igual que agentes y mesa); solo aparecen los proveedores con su API
# key configurada arriba (no hay que reescribir la clave). Solo informa y no opera,
# salvo que puede dejar una NOTA DE DIRECCIÓN para la mesa cuando se lo pides (ver
# DIRECTOR_NOTE abajo).
ASSISTANT_PROVIDER=gemini
ASSISTANT_MODEL=gemini-3.5-flash
# Nota de dirección activa que la mesa pondera en sus decisiones de las siguientes
# rotaciones. NO la edites a mano: la fija/retira el asistente desde el chat cuando
# le pides instruir a la mesa ("dile a la mesa que..."). Persiste aquí para
# sobrevivir a reinicios. Vacío = sin nota.
DIRECTOR_NOTE=

# ============================================================
# OPENAI (opcional — requiere `pip install openai`)
# ============================================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# DEEPSEEK (opcional — API compatible con OpenAI, reutiliza el SDK `openai`)
# ============================================================
# Con la clave puesta, 'deepseek' aparece en el selector de modelo (agentes,
# mesa y asistente). Modelos: deepseek-v4-flash / deepseek-v4-pro (actuales) y
# deepseek-chat / deepseek-reasoner (obsoletos el 2026/07/24).
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# Modelos extra para el selector si DeepSeek añade más (coma). Opcional.
# DEEPSEEK_MODELS=deepseek-v4-flash,deepseek-v4-pro
# Pensamiento (thinking/Reasoner) de los modelos V4: el modelo se detiene a razonar
# antes de dar el OK. enabled (por defecto en V4) / disabled. No afecta a
# deepseek-chat (nunca piensa) ni a deepseek-reasoner (siempre piensa).
# DEEPSEEK_THINKING=enabled
# Profundidad del razonamiento en V4 cuando está activo: high / max. Vacío = el del modelo.
# DEEPSEEK_REASONING_EFFORT=high
# base_url por defecto: https://api.deepseek.com (cámbialo solo si usas un proxy)
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ============================================================
# OLLAMA (opcional — local; desactivado por defecto en VPS)
# ============================================================
OLLAMA_ENABLED=false
OLLAMA_MODELS=qwen3:8b

# ============================================================
# BOT
# ============================================================
# Símbolos sugeridos (la operativa real la define el agente seleccionado)
SYMBOLS=BTCUSD

# Selección de agentes guardada (la escribe el botón "Guardar selección" del
# dashboard, pestaña Agentes). JSON con los agentes a cargar al arrancar, su LLM y
# si están activos. Si está presente, main.py la ofrece como opción por defecto en
# vez de pedir la selección a mano. Vacío = selección interactiva en cada arranque.
# Ejemplo:
# ACTIVE_AGENTS=[{"name":"btc-agent","provider":"gemini","model":"gemini-2.0-flash","enabled":true}]
ACTIVE_AGENTS=

# ============================================================
# BASE DE DATOS
# ============================================================
# Archivo SQLite donde el bot persiste señales, órdenes, cierres, equity y la
# memoria de los agentes. El frontend NO la usa (va por la API), así que no hace
# falta un servidor de base de datos. Default: logs/bot.db.
DB_PATH=logs/bot.db

# ============================================================
# API / DASHBOARD (seguridad)
# ============================================================
# Interfaz donde escucha el API. 127.0.0.1 = solo local (recomendado).
# Ponlo en 0.0.0.0 SOLO si necesitas acceso remoto Y has configurado API_TOKEN.
API_HOST=127.0.0.1
# Token compartido. Si se define, las rutas que mutan estado (start/stop,
# cerrar posición, cambiar modelo, optimizar) exigen la cabecera X-API-Token.
# Déjalo vacío para uso puramente local sin token.
API_TOKEN=

# ============================================================
# GESTIÓN DE RIESGO
# ============================================================
# Circuit breaker: si la pérdida dentro de la ventana móvil (equity vs equity
# base al inicio de la ventana) supera este porcentaje, el bot deja de abrir
# operaciones (cooldown). 0 = desactivado.
MAX_DAILY_LOSS_PCT=0.05
# Duración de la ventana del circuit breaker en segundos (se rearma con un nuevo
# equity base al expirar). Default 21600 = 6 h.
RISK_LOSS_WINDOW_SECONDS=21600

# ============================================================
# COORDINADOR (MESA DE DIRECCIÓN)
# ============================================================
# Capa por encima de los agentes especialistas: un "director" LLM reparte
# capital y decide go/no-go por símbolo, con una capa de riesgo determinista
# (RiskBook) que impone topes duros. La mesa está SIEMPRE activa: todo el flujo
# es coordinado (no existe modo clásico).
# LLM del coordinador. Vacío = se hereda el del primer agente (se pregunta al
# arrancar). Provider: ollama | openai | gemini.
COORDINATOR_PROVIDER=
COORDINATOR_MODEL=
COORDINATOR_TEMPERATURE=0.2
# Permite al coordinador cerrar/reducir posiciones abiertas. false = solo decide
# entradas (kill-switch global del cierre automático: ni siquiera las guardias
# deterministas cierran).
COORDINATOR_CAN_CLOSE=true
# Permite la gestión DISCRECIONAL del LLM (reduce/close/hedge "por criterio",
# p.ej. por exposición). false (default) = la mesa solo cierra por FUERZA MAYOR
# (guardias deterministas: hard-stop y reversión); las posiciones tienen su
# propio Stop Loss y se respeta. Ponlo a true solo si quieres que el LLM pueda
# gestionar posiciones abiertas a su criterio.
COORDINATOR_LLM_CAN_CLOSE=false
# Topes duros (no negociables) que el RiskBook impone sobre lo que proponga el LLM:
#   - exposición total máxima (margen usado / equity)
MAX_TOTAL_EXPOSURE_PCT=0.5
#   - asignación máxima de capital por símbolo (fracción del equity)
MAX_SYMBOL_ALLOCATION_PCT=0.4
# --- Control de concentración direccional / reversión de tendencia ---
# Tope de exposición NETA direccional por símbolo (fracción del equity). Frena
# seguir apilando posiciones en la dirección ya saturada (la entrada opuesta,
# que reduce el neto, sí se permite).
MAX_NET_DIRECTION_PCT=0.6
# Piramidar ganadores (add-to-winners): tope SUPERIOR del sesgo neto tolerado
# SOLO cuando la posición neta del símbolo va en GANANCIA y la tendencia del
# especialista confirma la dirección. Permite añadir a una tendencia ganadora más
# allá de MAX_NET_DIRECTION_PCT (nunca a perdedores ni contra tendencia). Si no se
# define, vale lo mismo que MAX_NET_DIRECTION_PCT (sin piramidación extra).
MAX_PYRAMID_DIRECTION_PCT=0.6
# Pérdida flotante (sobre el equity) que, JUNTO a un conflicto entre el sesgo
# abierto (neto LONG/SHORT) y la tendencia nueva, fuerza reducir/cerrar el lado
# perdedor (close si la pérdida es >= 2x este valor). El conflicto lo dispara el
# label de tendencia del LLM O el MOMENTO determinista que adjunta el especialista
# (pendiente EMA + ruptura de estructura + MACD; menos rezagado, reacciona antes a
# los giros). 0 = desactiva la guardia de reversión.
REVERSAL_DRAWDOWN_PCT=0.015
# Hard-stop por símbolo independiente de la tendencia: si la pérdida flotante
# del símbolo supera este % del equity, se fuerza el cierre. 0 = desactivado.
MAX_SYMBOL_LOSS_PCT=0
# Período de gracia (segundos) para posiciones recién abiertas: mientras la
# posición más reciente de un símbolo sea más joven que esto, la guardia de
# reversión se pausa y un reduce/close propuesto por el LLM se aplaza a "hold"
# (se le da tiempo a evolucionar). EXCEPCIÓN: un GIRO CONFIRMADO por estructura
# (ruptura de swing + momentum en contra del libro, con pérdida real) rompe la
# gracia y corta igualmente — es el caso "abrí justo en el techo y se giró". El
# hard-stop catastrófico también la rompe siempre.
# 0 = desactivado (la mesa puede gestionar al instante). Default 300 (5 min).
MIN_HOLD_SECONDS=300
# El coordinador también puede proponer position_action="hedge" (cubrir abriendo
# en sentido contrario). Solo surte efecto real en cuentas con hedging; en
# cuentas netting el RiskBook lo degrada a "reduce" automáticamente.
# Objetivo de beneficio (TP) gobernado por la mesa: para una entrada aprobada, el
# coordinador puede fijar un R:R objetivo (tp_rr) que recorta (rotación más rápida)
# o amplía el TP del especialista, manteniendo su Stop Loss. El RiskBook lo acota a
# este rango. Sin tp_rr informado se respeta el TP del especialista.
COORDINATOR_TP_RR_MIN=1.0
COORDINATOR_TP_RR_MAX=4.0
# Tamaño de posición (lote) gobernado por la mesa: para una entrada aprobada, el
# coordinador puede fijar un multiplicador EXPLÍCITO (size_mult) sobre el lote base
# del especialista. >1 agranda la entrada (convicción / piramidar ganadores), <1 la
# encoge; 1 (o ausente) = lote base. Es independiente de la asignación de capital
# (allocation_pct = presupuesto del símbolo). El RiskBook lo acota a este rango y el
# ajuste por margen libre + los topes de exposición recortan el lote final: size_mult
# nunca sobrepasa los límites duros.
COORDINATOR_SIZE_MULT_MIN=0.5
COORDINATOR_SIZE_MULT_MAX=2.0

# ============================================================
# PLANIFICADOR / CADENCIAS
# ============================================================
# El bot corre en un único bucle. La rotación es el tick base; las demás tareas
# se "abren" por tiempo. Todos los valores en SEGUNDOS.
#   - Rotación: analizar especialistas y, si procede, coordinar/ejecutar. SIEMPRE
#     se analiza cada rotación (sin análisis no hay confianza con la que decidir);
#     el nº máximo de posiciones lo gobierna la mesa (ver MAX_OPEN_POSITIONS_DEFAULT
#     y MAX_POSITIONS_HORIZON_MULT), no un throttle de análisis.
ROTATION_SECONDS=60
#   - Sonda de noticias: busca eventos RED (alto impacto) de los símbolos con
#     agente; uno nuevo fuerza una reacción vía mesa solo para ese símbolo.
NEWS_POLL_SECONDS=1800
#   - Junta de la mesa: revisión global del libro aunque la rotación no tenga
#     actividad (aplica guardias de reversión/hard-stop sobre lo abierto).
JUNTA_INTERVAL_SECONDS=3600
#   - Reporte: genera el informe y lo envía (si SMTP está activo, ver abajo).
REPORT_INTERVAL_SECONDS=7200
#   - Heartbeat de cuenta: refresca equity/balance y lo emite por WebSocket en un
#     hilo aparte, para que el P/L flotante del dashboard se mueva en vivo (no
#     espera al ciclo, que tarda ≥rotación + análisis LLM). 0 = desactivado.
ACCOUNT_POLL_SECONDS=5

# Análisis en paralelo (fase de recolección): lanza el análisis (LLM) de todos
# los agentes a la vez en cada rotación, reduciendo el tiempo de la fase ~Nx.
# Solo aporta si el backend LLM atiende peticiones concurrentes (nube
# OpenAI/Gemini, u Ollama con OLLAMA_NUM_PARALLEL>1 y VRAM suficiente); con un
# Ollama local de 1 GPU por defecto no acelera. Los accesos al EA se serializan
# solos (canal único). true por defecto; ponlo en false para volver a secuencial.
PARALLEL_ANALYSIS=true

# ============================================================
# REPORTE / EMAIL (SMTP)
# ============================================================
# Envío del reporte por correo. APAGADO por defecto: el reporte se genera y se
# muestra en consola/dashboard, pero no se envía hasta poner SMTP_ENABLED=true
# y configurar las credenciales. NUNCA subas credenciales reales al repo.
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Remitente (si vacío, se usa SMTP_USER).
SMTP_FROM=
# STARTTLS tras conectar (recomendado true en el puerto 587).
SMTP_USE_TLS=true
# Destinatario del reporte.
REPORT_EMAIL_TO=luismiguel.cano@blankpage.es

# ============================================================
# LÍMITES DE OPERACIONES MÁXIMAS
# ============================================================
# Nº máximo de posiciones abiertas POR SÍMBOLO. Lo GOBIERNA la mesa: el tope DURO
# que impone el RiskBook = base del perfil de RIESGO (MAX_OPEN_POSITIONS_DEFAULT)
# × multiplicador del HORIZONTE (MAX_POSITIONS_HORIZON_MULT). Una entrada aprobada
# que dejaría el símbolo por encima se veta; el LLM también lo ve en su prompt.
#   - MAX_OPEN_POSITIONS_DEFAULT: nº base de posiciones (lo escribe RISK_PROFILE).
#   - MAX_POSITIONS_HORIZON_MULT: multiplicador del horizonte (lo escribe HORIZON;
#     corto > 1 abre más concurrentes, largo < 1 menos). 0 en el base = sin tope.
#
# Precedencia para el resto de claves por agente: símbolo > modelo > default.
# Ejemplos:
#   MAX_OPEN_POSITIONS_BTCUSD=3       # BTCUSD: máximo 3 operaciones
#   MAX_OPEN_POSITIONS_EURUSD=2       # EURUSD: máximo 2 operaciones
#   MAX_OPEN_POSITIONS_QWEN3_8B=4     # qwen3:8b: máximo 4 operaciones
#   MAX_OPEN_POSITIONS_DEFAULT=5      # Fallback para cualquier símbolo/modelo
#
# Lo mismo aplica a otros umbrales de agente con sufijo _DEFAULT (afectan a TODOS
# los agentes salvo override por símbolo): MIN_CONFIDENCE_DEFAULT, MIN_RR_DEFAULT,
# ATR_TP_MULT_DEFAULT, ATR_SL_MULT_DEFAULT, TRAILING_BREAKEVEN_ATR_MULT_DEFAULT,
# TRAILING_STEP_ATR_MULT_DEFAULT, PARTIAL_PROFIT_TRIGGER_PCT_DEFAULT, etc. Los
# selectores de "Perfil de riesgo" y "Horizonte" del dashboard los escriben solos.
#
# Dos ejes INDEPENDIENTES, gestionados por sus selectores del dashboard (persisten
# aquí y se aplican en caliente, incluida la directiva que se inyecta en los prompts
# del especialista y de la mesa para que el LLM cambie de verdad su disposición):
#  - RISK_PROFILE: apetito/exposición/selectividad. conservative|moderate|aggressive|extreme.
#    Mueve los topes de la mesa, la piramidación, MIN_CONFIDENCE/MIN_RR y el nº BASE de
#    posiciones por símbolo (MAX_OPEN_POSITIONS_DEFAULT).
#  - HORIZON: duración de las operaciones. corto|medio|largo. Mueve el R:R objetivo
#    (COORDINATOR_TP_RR_*), ATR TP/SL, el periodo de gracia, trailing/parcial y el
#    multiplicador del nº de posiciones (MAX_POSITIONS_HORIZON_MULT).
RISK_PROFILE=moderate
HORIZON=medio
#
# Si no configuras nada, cada agente usa su valor por defecto del blueprint.
# Déjalos comentados/vacíos para usar los defaults del proyecto.
#
# MAX_OPEN_POSITIONS_BTCUSD=3
# MAX_OPEN_POSITIONS_DEFAULT=5

# ============================================================
# PARÁMETROS AVANZADOS POR SÍMBOLO/MODELO
# ============================================================
# También puedes ajustar otros parámetros del agente desde .env con la misma
# precedencia: símbolo > modelo > default.
#
# Parámetros soportados:
#   - min_confidence: umbral mínimo de confianza de la señal (0.0 a 1.0)
#   - min_rr: ratio riesgo/recompensa mínimo
#   - atr_sl_mult: multiplicador ATR para stop loss
#   - atr_tp_mult: multiplicador ATR para take profit
#   - max_spread_filter: máximo spread permitido (en puntos)
#   - risk_per_trade: riesgo máximo por operación (0.0 a 1.0)
#   - lot_size: tamaño de posición fijo (si use_risk_sizing=false)
#   - temperature: temperatura del modelo LLM (0.0 a 2.0)
#
# Ejemplos:
#   MIN_CONFIDENCE_BTCUSD=0.65
#   MIN_RR_QWEN3_8B=1.8
#   ATR_SL_MULT_DEFAULT=1.5
#   RISK_PER_TRADE_DEFAULT=0.02
#
# Déjalos comentados/vacíos para usar los defaults de cada blueprint.
#
# MIN_CONFIDENCE_BTCUSD=0.65
# MIN_RR_DEFAULT=1.5

# ============================================================
# COMISIÓN
# ============================================================
# Comisión por lote en USD. Se aplica en el cálculo de profit/pérdida.
# Ejemplo: comisión de 0.13$ por lote
# COMMISSION_PER_LOT=0.13
#
# NOTA: esto es solo la SEMILLA/FALLBACK. El bot deduce la comisión real por
# lote de las posiciones abiertas en MT (OrderCommission()/volumen) y la usa
# en cuanto haya datos del símbolo; el valor de aquí se aplica solo mientras
# ese símbolo no tenga posiciones de las que aprender. Requiere el EA
# PythonBridge.mq4 recompilado (reporta `commission` en POSITIONS).
