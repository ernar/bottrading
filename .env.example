# ============================================================
# Plantilla de configuración. Copia este archivo a `.env` y rellena
# tus valores reales. NUNCA subas el `.env` al repositorio.
# ============================================================

# PLATAFORMA: exclusiva MT4 (EA bridge)
MT_VERSION=mt4

# ============================================================
# MT4 (EA bridge - PythonBridge.mq4)
# ============================================================
MT4_LOGIN=0
MT4_PASSWORD=
MT4_HOST=127.0.0.1
MT4_PORT=8765

# ============================================================
# GOOGLE GEMINI — proveedor principal
# ============================================================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Proveedor activo: gemini | openai | ollama
AI_PROVIDER=gemini
# Modelo por defecto (se sobreescribe al iniciar el bot)
MODEL=gemini-2.0-flash

# ============================================================
# OPENAI (opcional — requiere `pip install openai`)
# ============================================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# OLLAMA (opcional — local; desactivado por defecto en VPS)
# ============================================================
OLLAMA_ENABLED=false
OLLAMA_MODELS=qwen3:8b

# ============================================================
# BOT
# ============================================================
# Símbolos sugeridos (la operativa real la define el agente seleccionado)
SYMBOLS=BTCUSD

# ============================================================
# API / DASHBOARD (seguridad)
# ============================================================
# Interfaz donde escucha el API. 127.0.0.1 = solo local (recomendado).
# Ponlo en 0.0.0.0 SOLO si necesitas acceso remoto Y has configurado API_TOKEN.
API_HOST=127.0.0.1
# Token compartido. Si se define, las rutas que mutan estado (start/stop,
# cerrar posición, cambiar modelo, optimizar) exigen la cabecera X-API-Token.
# Déjalo vacío para uso puramente local sin token.
API_TOKEN=

# ============================================================
# GESTIÓN DE RIESGO
# ============================================================
# Circuit breaker: si la pérdida del día (equity vs balance inicial del día)
# supera este porcentaje, el bot deja de abrir operaciones. 0 = desactivado.
MAX_DAILY_LOSS_PCT=0.05

# ============================================================
# COORDINADOR (MESA DE DIRECCIÓN)
# ============================================================
# Capa por encima de los agentes especialistas: un "director" LLM reparte
# capital y decide go/no-go por símbolo, con una capa de riesgo determinista
# (RiskBook) que impone topes duros. Si se desactiva, el bot vuelve al modo
# clásico (cada agente ejecuta su propia señal de forma aislada).
COORDINATOR_ENABLED=true
# LLM del coordinador. Vacío = se hereda el del primer agente (se pregunta al
# arrancar). Provider: ollama | openai | gemini.
COORDINATOR_PROVIDER=
COORDINATOR_MODEL=
COORDINATOR_TEMPERATURE=0.2
# Permite al coordinador cerrar/reducir posiciones abiertas. false = solo decide
# entradas (kill-switch global del cierre automático: ni siquiera las guardias
# deterministas cierran).
COORDINATOR_CAN_CLOSE=true
# Permite la gestión DISCRECIONAL del LLM (reduce/close/hedge "por criterio",
# p.ej. por exposición). false (default) = la mesa solo cierra por FUERZA MAYOR
# (guardias deterministas: hard-stop y reversión); las posiciones tienen su
# propio Stop Loss y se respeta. Ponlo a true solo si quieres que el LLM pueda
# gestionar posiciones abiertas a su criterio.
COORDINATOR_LLM_CAN_CLOSE=false
# Topes duros (no negociables) que el RiskBook impone sobre lo que proponga el LLM:
#   - exposición total máxima (margen usado / equity)
MAX_TOTAL_EXPOSURE_PCT=0.5
#   - asignación máxima de capital por símbolo (fracción del equity)
MAX_SYMBOL_ALLOCATION_PCT=0.4
# --- Control de concentración direccional / reversión de tendencia ---
# Tope de exposición NETA direccional por símbolo (fracción del equity). Frena
# seguir apilando posiciones en la dirección ya saturada (la entrada opuesta,
# que reduce el neto, sí se permite).
MAX_NET_DIRECTION_PCT=0.6
# Pérdida flotante (sobre el equity) que, JUNTO a un conflicto entre el sesgo
# abierto (neto LONG/SHORT) y la tendencia nueva del especialista, fuerza
# reducir/cerrar el lado perdedor (close si la pérdida es >= 2x este valor).
# 0 = desactiva la guardia de reversión.
REVERSAL_DRAWDOWN_PCT=0.015
# Hard-stop por símbolo independiente de la tendencia: si la pérdida flotante
# del símbolo supera este % del equity, se fuerza el cierre. 0 = desactivado.
MAX_SYMBOL_LOSS_PCT=0
# Período de gracia (segundos) para posiciones recién abiertas: mientras la
# posición más reciente de un símbolo sea más joven que esto, la guardia de
# reversión se pausa y un reduce/close propuesto por el LLM se aplaza a "hold"
# (se le da tiempo a evolucionar). Solo el hard-stop catastrófico lo rompe.
# 0 = desactivado (la mesa puede gestionar al instante). Default 300 (5 min).
MIN_HOLD_SECONDS=300
# El coordinador también puede proponer position_action="hedge" (cubrir abriendo
# en sentido contrario). Solo surte efecto real en cuentas con hedging; en
# cuentas netting el RiskBook lo degrada a "reduce" automáticamente.

# ============================================================
# PLANIFICADOR / CADENCIAS
# ============================================================
# El bot corre en un único bucle. La rotación es el tick base; las demás tareas
# se "abren" por tiempo. Todos los valores en SEGUNDOS.
#   - Rotación: analizar especialistas y, si procede, coordinar/ejecutar.
ROTATION_SECONDS=60
#   - Sonda de noticias: busca eventos RED (alto impacto) de los símbolos con
#     agente; uno nuevo fuerza una reacción vía mesa solo para ese símbolo.
NEWS_POLL_SECONDS=1800
#   - Junta de la mesa: revisión global del libro aunque la rotación no tenga
#     actividad (aplica guardias de reversión/hard-stop sobre lo abierto).
JUNTA_INTERVAL_SECONDS=3600
#   - Reporte: genera el informe y lo envía (si SMTP está activo, ver abajo).
REPORT_INTERVAL_SECONDS=7200

# ============================================================
# REPORTE / EMAIL (SMTP)
# ============================================================
# Envío del reporte por correo. APAGADO por defecto: el reporte se genera y se
# muestra en consola/dashboard, pero no se envía hasta poner SMTP_ENABLED=true
# y configurar las credenciales. NUNCA subas credenciales reales al repo.
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Remitente (si vacío, se usa SMTP_USER).
SMTP_FROM=
# STARTTLS tras conectar (recomendado true en el puerto 587).
SMTP_USE_TLS=true
# Destinatario del reporte.
REPORT_EMAIL_TO=luismiguel.cano@blankpage.es

# ============================================================
# LÍMITES DE OPERACIONES MÁXIMAS
# ============================================================
# Configura cuántas operaciones máximas puede tener abiertas cada agente.
# Precedencia: símbolo > modelo > default.
#
# Ejemplos:
#   MAX_OPEN_POSITIONS_BTCUSD=3       # BTCUSD: máximo 3 operaciones
#   MAX_OPEN_POSITIONS_EURUSD=2       # EURUSD: máximo 2 operaciones
#   MAX_OPEN_POSITIONS_QWEN3_8B=4     # qwen3:8b: máximo 4 operaciones
#   MAX_OPEN_POSITIONS_DEFAULT=5      # Fallback para cualquier símbolo/modelo
#
# Si no configuras nada, cada agente usa su valor por defecto del blueprint.
# Déjalos comentados/vacíos para usar los defaults del proyecto.
#
# MAX_OPEN_POSITIONS_BTCUSD=3
# MAX_OPEN_POSITIONS_DEFAULT=5

# ============================================================
# PARÁMETROS AVANZADOS POR SÍMBOLO/MODELO
# ============================================================
# También puedes ajustar otros parámetros del agente desde .env con la misma
# precedencia: símbolo > modelo > default.
#
# Parámetros soportados:
#   - min_confidence: umbral mínimo de confianza de la señal (0.0 a 1.0)
#   - min_rr: ratio riesgo/recompensa mínimo
#   - atr_sl_mult: multiplicador ATR para stop loss
#   - atr_tp_mult: multiplicador ATR para take profit
#   - max_spread_filter: máximo spread permitido (en puntos)
#   - risk_per_trade: riesgo máximo por operación (0.0 a 1.0)
#   - lot_size: tamaño de posición fijo (si use_risk_sizing=false)
#   - temperature: temperatura del modelo LLM (0.0 a 2.0)
#
# Ejemplos:
#   MIN_CONFIDENCE_BTCUSD=0.65
#   MIN_RR_QWEN3_8B=1.8
#   ATR_SL_MULT_DEFAULT=1.5
#   RISK_PER_TRADE_DEFAULT=0.02
#
# Déjalos comentados/vacíos para usar los defaults de cada blueprint.
#
# MIN_CONFIDENCE_BTCUSD=0.65
# MIN_RR_DEFAULT=1.5

# ============================================================
# COMISIÓN
# ============================================================
# Comisión por lote en USD. Se aplica en el cálculo de profit/pérdida.
# Ejemplo: comisión de 0.13$ por lote
# COMMISSION_PER_LOT=0.13
#
# NOTA: esto es solo la SEMILLA/FALLBACK. El bot deduce la comisión real por
# lote de las posiciones abiertas en MT (OrderCommission()/volumen) y la usa
# en cuanto haya datos del símbolo; el valor de aquí se aplica solo mientras
# ese símbolo no tenga posiciones de las que aprender. Requiere el EA
# PythonBridge.mq4 recompilado (reporta `commission` en POSITIONS).
